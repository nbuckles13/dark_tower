#!/bin/bash
# dev-cluster — Client CLI for the devloop-helper host-side process.
#
# Sends commands to the helper via unix socket and streams responses.
# Used by Claude Code inside the dev container to manage Kind clusters.
#
# Usage:
#   dev-cluster setup [--skip-observability]
#   dev-cluster rebuild <service>
#   dev-cluster rebuild-all
#   dev-cluster deploy <service>
#   dev-cluster teardown
#
# Services: ac, gc, mc, mh
#
# See: docs/decisions/adr-0030-host-side-cluster-helper.md

set -euo pipefail

# ─── Configuration ──────────────────────────────────────────────

SOCKET="/tmp/devloop/helper.sock"
TOKEN_FILE="/tmp/devloop/auth-token"
PORTS_FILE="/tmp/devloop/ports.json"

# ─── Argument parsing ───────────────────────────────────────────

if [ $# -lt 1 ]; then
    echo "Usage: dev-cluster <command> [args]" >&2
    echo "" >&2
    echo "Commands:" >&2
    echo "  setup [--skip-observability]    Create Kind cluster and deploy services" >&2
    echo "  rebuild <service>               Rebuild one service image and restart" >&2
    echo "  rebuild-all                     Rebuild all service images" >&2
    echo "  deploy <service>                Apply manifests only (no rebuild)" >&2
    echo "  teardown                        Delete Kind cluster and clean up" >&2
    echo "" >&2
    echo "Services: ac, gc, mc, mh" >&2
    exit 1
fi

CMD=""
SVC=""
SKIP_OBS="false"

case "$1" in
    setup)
        CMD="setup"
        shift
        while [ $# -gt 0 ]; do
            case "$1" in
                --skip-observability) SKIP_OBS="true"; shift ;;
                *) echo "ERROR: Unknown option for setup: $1" >&2; exit 1 ;;
            esac
        done
        ;;
    rebuild)
        CMD="rebuild"
        if [ $# -lt 2 ]; then
            echo "ERROR: rebuild requires a service argument (ac, gc, mc, mh)" >&2
            exit 1
        fi
        SVC="$2"
        ;;
    rebuild-all)
        CMD="rebuild-all"
        ;;
    deploy)
        CMD="deploy"
        if [ $# -lt 2 ]; then
            echo "ERROR: deploy requires a service argument (ac, gc, mc, mh)" >&2
            exit 1
        fi
        SVC="$2"
        ;;
    teardown)
        CMD="teardown"
        ;;
    *)
        echo "ERROR: Unknown command '$1'" >&2
        echo "Valid commands: setup, rebuild, rebuild-all, deploy, teardown" >&2
        exit 1
        ;;
esac

# Validate service name (defense-in-depth; helper also validates server-side)
if [ -n "$SVC" ]; then
    case "$SVC" in
        ac|gc|mc|mh) ;; # valid
        *)
            echo "ERROR: Invalid service '$SVC'. Must be one of: ac gc mc mh" >&2
            exit 1
            ;;
    esac
fi

# ─── Preflight checks ──────────────────────────────────────────

if [ ! -S "$SOCKET" ]; then
    echo "ERROR: Helper socket not found at $SOCKET" >&2
    echo "The devloop helper is not running." >&2
    echo "  - Check if /tmp/devloop/ is mounted: ls -la /tmp/devloop/" >&2
    echo "  - Re-run devloop.sh on the host to start the helper" >&2
    exit 1
fi

if [ ! -f "$TOKEN_FILE" ]; then
    echo "ERROR: Auth token not found at $TOKEN_FILE" >&2
    echo "The helper may need to be restarted (re-run devloop.sh on the host)." >&2
    exit 1
fi

TOKEN=$(cat "$TOKEN_FILE")

# Validate token format (64 hex characters, generated by helper's CSPRNG)
if ! [[ "$TOKEN" =~ ^[0-9a-f]{64}$ ]]; then
    echo "ERROR: Auth token has unexpected format (expected 64 hex chars)" >&2
    echo "The token file may be corrupted. Re-run devloop.sh to regenerate." >&2
    exit 1
fi

if ! command -v socat &>/dev/null; then
    echo "ERROR: socat not found. It should be installed in the dev container image." >&2
    exit 1
fi

if ! command -v jq &>/dev/null; then
    echo "ERROR: jq not found. It should be installed in the dev container image." >&2
    exit 1
fi

# ─── Build JSON request ────────────────────────────────────────

# Use jq to build valid JSON (no shell interpolation into JSON strings)
if [ -n "$SVC" ]; then
    REQUEST=$(jq -cn \
        --arg token "$TOKEN" \
        --arg cmd "$CMD" \
        --arg svc "$SVC" \
        '{token: $token, command: $cmd, service: $svc}')
elif [ "$SKIP_OBS" = "true" ]; then
    REQUEST=$(jq -cn \
        --arg token "$TOKEN" \
        --arg cmd "$CMD" \
        '{token: $token, command: $cmd, skip_observability: true}')
else
    REQUEST=$(jq -cn \
        --arg token "$TOKEN" \
        --arg cmd "$CMD" \
        '{token: $token, command: $cmd}')
fi

# ─── Send request and process streaming response ───────────────

EXIT_CODE=1
GOT_RESULT="false"

# socat connects to the unix socket, sends the request, reads streaming NDJSON.
# -t 600 = 10 minute idle timeout (setup can take ~7 min on first run).
# We use a temp file for the response stream to avoid subshell issues with
# variable scoping in pipelines.
RESPONSE_TMPDIR=$(mktemp -d /tmp/dev-cluster.XXXXXX)
RESPONSE_FIFO="$RESPONSE_TMPDIR/response"
mkfifo "$RESPONSE_FIFO"
trap 'rm -rf "$RESPONSE_TMPDIR"' EXIT

# Start socat in the background, writing responses to the FIFO
echo "$REQUEST" | socat -t 600 STDIO "UNIX-CONNECT:$SOCKET" > "$RESPONSE_FIFO" 2>/dev/null &
SOCAT_PID=$!

# Check if socat connected successfully (give it enough time to fail on
# connection refused / socket not found before we start reading the FIFO)
sleep 0.5
if ! kill -0 "$SOCAT_PID" 2>/dev/null; then
    # socat exited immediately — connection failed
    echo "ERROR: Cannot connect to helper socket at $SOCKET" >&2
    echo "The helper process may have crashed." >&2
    echo "  - Check helper log:    cat /tmp/devloop/helper.log" >&2
    echo "  - Check helper stderr: cat /tmp/devloop/helper-stderr.log" >&2
    echo "  - Helper PID: $(cat /tmp/devloop/helper.pid 2>/dev/null || echo 'not found')" >&2
    echo "  - Re-run devloop.sh on the host to restart the helper" >&2
    exit 1
fi

# Read and parse NDJSON lines from the response stream
while IFS= read -r line; do
    # Skip empty lines
    [ -z "$line" ] && continue

    # Determine message type by checking for distinctive fields
    msg_type=$(echo "$line" | jq -r '
        if .started != null then "started"
        elif .stream != null then "stream"
        elif .result != null then "result"
        elif .success != null then "error"
        else "unknown"
        end' 2>/dev/null || echo "unknown")

    case "$msg_type" in
        started)
            # CommandStarted: print status header
            cmd_name=$(echo "$line" | jq -r '.cmd')
            ts=$(echo "$line" | jq -r '.ts')
            echo "=== ${cmd_name} started at ${ts} ===" >&2
            ;;

        stream)
            # StreamLine: route to stdout or stderr based on stream field
            stream_kind=$(echo "$line" | jq -r '.stream')
            content=$(echo "$line" | jq -r '.line')
            if [ "$stream_kind" = "err" ]; then
                echo "$content" >&2
            else
                echo "$content"
            fi
            ;;

        result)
            # CommandResult: print summary and set exit code
            GOT_RESULT="true"
            result_status=$(echo "$line" | jq -r '.result')
            exit_code=$(echo "$line" | jq -r '.exit_code // -1')
            duration_ms=$(echo "$line" | jq -r '.duration_ms')
            error_msg=$(echo "$line" | jq -r '.error // empty')
            duration_s=$(echo "scale=1; ${duration_ms} / 1000" | bc)

            if [ "$result_status" = "ok" ]; then
                echo "=== ${CMD} completed (exit ${exit_code}, ${duration_s}s) ===" >&2
                EXIT_CODE=0
            else
                echo "=== ${CMD} FAILED (exit ${exit_code}, ${duration_s}s)${error_msg:+: ${error_msg}} ===" >&2
                if [ "$exit_code" != "null" ] && [ "$exit_code" != "-1" ]; then
                    EXIT_CODE="$exit_code"
                else
                    EXIT_CODE=1
                fi
            fi
            ;;

        error)
            # Pre-execution error response (auth failure, invalid request, etc.)
            GOT_RESULT="true"
            error_msg=$(echo "$line" | jq -r '.message')
            error_kind=$(echo "$line" | jq -r '.error_kind // "unknown"')
            echo "ERROR: ${error_msg} (${error_kind})" >&2
            if [ "$error_kind" = "auth_failed" ]; then
                echo "The auth token may have rotated. Re-run devloop.sh to refresh." >&2
            fi
            EXIT_CODE=1
            ;;

        *)
            # Unknown message type — print raw for debugging
            echo "[dev-cluster] unknown response: $line" >&2
            ;;
    esac
done < "$RESPONSE_FIFO"

# Wait for socat to finish
wait "$SOCAT_PID" 2>/dev/null || true

# Check if we got a complete response
if [ "$GOT_RESULT" = "false" ]; then
    echo "ERROR: Helper connection lost before command completed" >&2
    echo "The helper may have crashed. Check:" >&2
    echo "  - Helper log:    cat /tmp/devloop/helper.log" >&2
    echo "  - Helper stderr: cat /tmp/devloop/helper-stderr.log" >&2
    echo "  - Helper PID:    $(cat /tmp/devloop/helper.pid 2>/dev/null || echo 'not found')" >&2
    exit 1
fi

# ─── Post-command summary ──────────────────────────────────────

# After successful setup, display cluster URLs from port map
if [ "$CMD" = "setup" ] && [ "$EXIT_CODE" -eq 0 ] && [ -f "$PORTS_FILE" ]; then
    echo "" >&2
    cluster_name=$(jq -r '.cluster_name // "unknown"' "$PORTS_FILE")
    echo "=== Cluster ready: ${cluster_name} ===" >&2
    echo "" >&2

    # Service URLs (for use inside the container)
    ac_url=$(jq -r '.container_urls.ac // empty' "$PORTS_FILE")
    gc_url=$(jq -r '.container_urls.gc // empty' "$PORTS_FILE")
    echo "Service URLs (from container):" >&2
    [ -n "$ac_url" ] && echo "  AC:         $ac_url" >&2
    [ -n "$gc_url" ] && echo "  GC:         $gc_url" >&2

    # Observability URLs
    grafana_url=$(jq -r '.container_urls.grafana // empty' "$PORTS_FILE")
    prometheus_url=$(jq -r '.container_urls.prometheus // empty' "$PORTS_FILE")
    loki_url=$(jq -r '.container_urls.loki // empty' "$PORTS_FILE")
    echo "" >&2
    if [ -n "$grafana_url" ]; then
        echo "Observability (from container):" >&2
        echo "  Grafana:    $grafana_url" >&2
        echo "  Prometheus: $prometheus_url" >&2
        echo "  Loki:       $loki_url" >&2
    else
        echo "Observability: not deployed (--skip-observability)" >&2
    fi

    # K8s API
    k8s_port=$(jq -r '.ports.k8s_api // empty' "$PORTS_FILE")
    host=$(jq -r '.host // "host.containers.internal"' "$PORTS_FILE")
    if [ -n "$k8s_port" ]; then
        echo "" >&2
        echo "K8s API:      https://${host}:${k8s_port}" >&2
    fi

    echo "Kubeconfig:   /tmp/devloop/kubeconfig" >&2
    echo "Port map:     $PORTS_FILE" >&2

    # Env-test variables (copy-paste ready for cargo test -p env-tests)
    echo "" >&2
    echo "Env-test variables:" >&2
    [ -n "$ac_url" ] && echo "  ENV_TEST_AC_URL=$ac_url" >&2
    [ -n "$gc_url" ] && echo "  ENV_TEST_GC_URL=$gc_url" >&2
    [ -n "$prometheus_url" ] && echo "  ENV_TEST_PROMETHEUS_URL=$prometheus_url" >&2
    [ -n "$grafana_url" ] && echo "  ENV_TEST_GRAFANA_URL=$grafana_url" >&2
    [ -n "$loki_url" ] && echo "  ENV_TEST_LOKI_URL=$loki_url" >&2

    # Host URLs for human browser access (ADR-0030)
    prometheus_host=$(jq -r '.host_urls.prometheus // empty' "$PORTS_FILE")
    grafana_host=$(jq -r '.host_urls.grafana // empty' "$PORTS_FILE")
    loki_host=$(jq -r '.host_urls.loki // empty' "$PORTS_FILE")
    if [ -n "$grafana_host" ]; then
        echo "" >&2
        echo "Browser access (from host):" >&2
        echo "  Prometheus: $prometheus_host" >&2
        echo "  Grafana:    $grafana_host" >&2
        echo "  Loki:       $loki_host" >&2
    fi
fi

exit "$EXIT_CODE"
