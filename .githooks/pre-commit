#!/bin/bash
#
# Pre-commit hook for Dark Tower project
# Automatically runs cargo fmt and cargo clippy before each commit
#

set -e

echo "🔍 Running pre-commit checks..."

# Check code formatting (does NOT format, only checks)
echo "  ➜ Checking code formatting with cargo fmt..."
cargo fmt --all -- --check
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Code formatting issues detected!"
    echo "   Run 'cargo fmt' to fix formatting, then commit again."
    exit 1
fi

# Run cargo clippy on changed Rust files
echo "  ➜ Running clippy on changed files..."
if git diff --cached --name-only | grep -q "\.rs$"; then
    cargo clippy --all-targets --all-features -- -D warnings
    if [ $? -ne 0 ]; then
        echo ""
        echo "❌ Clippy warnings/errors detected!"
        echo "   Fix the issues and commit again."
        exit 1
    fi
fi

# Check devloop main.md files for unfilled sections
DEVLOOP_ERRORS=""
for f in $(git diff --cached --name-only | grep 'docs/devloop-outputs/.*/main\.md$'); do
    # Check for TBD placeholders (unfilled sections)
    tbds=$(git show ":$f" | grep -n '^TBD$' || true)
    if [ -n "$tbds" ]; then
        DEVLOOP_ERRORS="${DEVLOOP_ERRORS}  $f: has unfilled TBD sections\n"
    fi
    # Check for pending reviewers in Loop State table
    pending=$(git show ":$f" | grep -P '\|\s*`?pending`?\s*\|' || true)
    if [ -n "$pending" ]; then
        DEVLOOP_ERRORS="${DEVLOOP_ERRORS}  $f: has pending reviewers in Loop State\n"
    fi
done
if [ -n "$DEVLOOP_ERRORS" ]; then
    echo ""
    echo "❌ Devloop output main.md incomplete:"
    echo -e "$DEVLOOP_ERRORS"
    echo "   Fill in all TBD sections and reviewer names before committing."
    exit 1
fi

echo "✅ All pre-commit checks passed!"
exit 0
